---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsList from "../components/NewsList.astro";
import SocialIcons from "../components/SocialIcons.astro";
import site from "../data/site.json";
import profilePic from "../assets/images/prof_pic.jpg";
---

<BaseLayout>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{site.title}</h1>
      <p class="desc">First-Year M.S. Student</p>
    </header>

    <article>
      <div class="profile">
        <Image
          src={profilePic}
          alt={site.title}
          width={600}
          loading="eager"
          style="width:100%;height:auto;aspect-ratio:1/1;object-fit:cover;"
        />
      </div>

      <div class="clearfix">
        <p>
          I am a first-year M.S. student in School of Computing at KAIST, Republic of Korea, advised by
          <a href="https://sites.google.com/view/yjkwon/home" target="_blank" rel="noopener noreferrer">Prof. Youngjin Kwon</a>
          of the
          <a href="https://casyslab.kaist.ac.kr/" target="_blank" rel="noopener noreferrer">Computer Architecture and Systems Lab (CASYS)</a>. Previously, I
          received my Bachelor's degree in February, 2026 from KAIST.
        </p>

        <h3>Research Interests</h3>
        <ul>
          <li>
            <strong>Operating Systems</strong>
            <ul>
              <li>File & Storage Systems</li>
              <li>Kernel-level Optimization</li>
            </ul>
          </li>
          <li>
            <strong>Computer Architecture</strong>
            <ul>
              <li>Unified Memory Architectures</li>
            </ul>
          </li>
        </ul>

        <h3>Education</h3>
        <ul>
          <li><strong>M.S. in School of Computing</strong>, KAIST, Mar. 2026 ~ Current</li>
          <li><strong>B.S. in School of Computing</strong>, KAIST, Mar. 2021 ~ Feb. 2026</li>
        </ul>
      </div>

      <h2><a href="/news/">News</a></h2>
      <NewsList limit={5} scrollable={true} />

      <div class="social">
        <SocialIcons />
        <p class="contact-note">{site.contactNote}</p>
      </div>
    </article>
  </div>
</BaseLayout>
